BACKEND_PORT=5001
# Optional bind host. Use 0.0.0.0 to accept LAN connections.
BACKEND_HOST=
# Optional public/backend URL shown in startup logs, such as http://192.168.1.25:5001 or https://api.example.com.
BACKEND_PUBLIC_URL=
JWT_SECRET=your-super-secret-jwt-key-change-in-production
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key-change-in-production
# Keep this value stable. Changing it makes previously encrypted messages unreadable.
MESSAGE_ENCRYPTION_KEY=use-a-long-random-message-encryption-key
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
# Optional comma-separated frontend origins for CORS/WebSockets.
FRONTEND_URLS=

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=cad_police
MYSQL_CONNECTION_LIMIT=10
MYSQL_SSL=false
MYSQL_SSL_CA_PATH=
MYSQL_SSL_REJECT_UNAUTHORIZED=true

# Security controls
ENFORCE_HTTPS=false
IP_ALLOWLIST=
IP_BLOCKLIST=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=240
SENSITIVE_RATE_LIMIT_WINDOW_MS=900000
SENSITIVE_RATE_LIMIT_MAX_REQUESTS=30
PASSWORD_MIN_LENGTH=12
PASSWORD_HISTORY_COUNT=5
PASSWORD_MAX_AGE_DAYS=180
REQUEST_SIGNING_SECRET=
REQUEST_SIGNING_MAX_AGE_MS=300000

# Initial admin user, created only when the users table is empty
SEED_ADMIN_EMAIL=admin@dispatch.local
SEED_ADMIN_PASSWORD=ChangeMe123!Secure
SEED_ADMIN_NAME=System Administrator
SEED_ADMIN_BADGE=ADM001
