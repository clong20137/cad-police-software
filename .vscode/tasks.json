{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install All Dependencies",
      "type": "shell",
      "command": "npm",
      "args": ["run", "install-all"],
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Dev - Frontend + Backend",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*",
          "endsPattern": "Compiled|started"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Dev - Backend Only",
      "type": "shell",
      "command": "npm",
      "args": ["run", "server"],
      "isBackground": true,
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Dev - Frontend Only",
      "type": "shell",
      "command": "npm",
      "args": ["run", "client"],
      "isBackground": true,
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Build All",
      "type": "shell",
      "command": "npm",
      "args": ["run", "build"],
      "problemMatcher": ["$tsc"],
      "group": "build"
    },
    {
      "label": "Lint All",
      "type": "shell",
      "command": "npm",
      "args": ["run", "lint"],
      "problemMatcher": ["$eslint-stylish"],
      "group": "build"
    }
  ]
}
